---
// 1. ファイルの【一番最初】にハイフン3つがあり、ここでインポートやデータ取得を行います
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import DocViewer from '../components/DocViewer'; // 元のDocViewerのインポート
import '../styles/global.css';

// Markdownのコレクション（blog）から全記事データを自動取得
const allPosts = await getCollection('blog');

// 取得したMarkdownデータを、SidebarやDocViewerが読めるカテゴリ構造に自動変換
const categories = [
  {
    id: 'cat_docker',
    name: '🐳 インフラ・Docker',
    articles: allPosts
      .filter(post => post.data.category === '🐳 インフラ・Docker')
      .map(post => ({
        id: post.slug,
        title: post.data.title,
        content: post.body // Markdownの本文をそのまま流し込む
      }))
  }
];
---
{/* ↑ここで【絶対に一度だけ】ハイフン3つを閉じる。これより下はHTML/JSXエリアです */}

<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Kazuki's Docs</title>
	</head>
	<body class="min-h-screen bg-gray-50 flex flex-col">
		<header class="bg-white border-b border-gray-200 px-6 py-4">
			<h1 class="text-xl font-bold text-gray-800">Kazuki's Docs</h1>
		</header>

		{/* データをReactコンポーネントに渡して起動 */}
		<DocViewer client:load initialCategories={categories} />
	</body>
</html>